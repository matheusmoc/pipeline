# Variaveis de Ambiente - Exemplo
#
# Copie este arquivo para .env e preencha os valores
# conforme o ambiente desejado (desenvolvimento, producao).

# Aplicacao
APP_NAME=FastAPI Seminario CI/CD
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True

# Banco de Dados
DATABASE_URL=sqlite:///./app.db

# Servidor
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# Docker
DOCKER_IMAGE=fastapi-seminario:latest
